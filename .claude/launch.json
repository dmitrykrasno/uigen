{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Vitest UI",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vitest", "--ui", "--port", "51204"],
      "port": 51204
    }
  ,{
      "name": "Cheat Sheets",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "cheat_sheets", "--listen", "3001", "--no-clipboard"],
      "port": 3001
    }
  ]
}
